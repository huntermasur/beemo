# Environment variables for {{projectName}} — copy to `.env` and fill in real values.
# Policy (gitignored .env, VITE_ prefix, keeping this file in sync): .docs/environment.md

# Example: public app title exposed to the frontend
VITE_APP_TITLE={{projectName}}

# Example: base URL of your API (uncomment and set as needed)
# VITE_API_BASE_URL=http://localhost:3000
